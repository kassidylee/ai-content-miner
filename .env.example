# Copy this file to .env and replace the placeholders.
# Never commit the resulting .env file.
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=your-model-name

# Optional. Fill these only when the corresponding Embedding route is enabled.
EMBEDDING_MODEL=text-embedding-3-small
TWITTER_EMBEDDING_MODEL=text-embedding-3-small

# Optional. Required only when the corresponding notification flow is enabled.
WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-webhook-key
